---
import Layout from '../layouts/Layout.astro';
import PublicationCard from '../components/PublicationCard.astro';

const selected = [
  {
    title: 'Alu-mediated RNA duplexes are associated with widespread exon skipping across primate transcriptomes',
    authors: 'Lee, H.*; Cao, X.*; Parada, G.E.*#; Li, J.D.; Iosub, I.A.; Braunschweig, U.; Rebelo, K.; Ule, J.; Wan, Y.#; Blencowe, B.J.#',
    venue: 'Genome Biology',
    year: '2026',
    contribution:
      'Co-first and co-corresponding author; helped establish RNA duplexes as a major layer of primate-specific splicing regulation.',
    links: [
      { label: 'DOI', href: 'https://doi.org/10.1186/s13059-026-04029-7' },
    ],
  },
  {
    title: 'Alternative splicing modulation by G-quadruplexes',
    authors: 'Georgakopoulos-Soares, I.*; Parada, G.E.*; Wong, H.Y.; Medhi, R.; Furlan, G.; Munita, R.; et al.',
    venue: 'Nature Communications',
    year: '2022',
    contribution:
      'Co-led the study and analyses; showed that G-quadruplex structures modulate alternative splicing transcriptome-wide.',
    links: [
      { label: 'DOI', href: 'https://doi.org/10.1038/s41467-022-30071-7' },
    ],
  },
  {
    title: 'MicroExonator enables systematic discovery and quantification of microexons across mouse embryonic development',
    authors: 'Parada, G.E.; Munita, R.; Georgakopoulos-Soares, I.; Fernandes, H.J.R.; Kedlian, V.R.; Metzakopian, E.; et al.',
    venue: 'Genome Biology',
    year: '2021',
    contribution:
      'Sole first author; developed MicroExonator and generated a systematic microexon atlas across mouse development.',
    links: [
      { label: 'DOI', href: 'https://doi.org/10.1186/s13059-020-02246-2' },
      { label: 'Code', href: 'https://github.com/hemberg-lab/MicroExonator' },
    ],
  },
  {
    title: 'A comprehensive survey of non-canonical splice sites in the human transcriptome',
    authors: 'Parada, G.E.*; Munita, R.*; Cerda, C.A.; Gysling, K.#',
    venue: 'Nucleic Acids Research',
    year: '2014',
    contribution:
      'Co-first author; mapped high-confidence non-canonical splice sites in the human transcriptome.',
    links: [
      { label: 'DOI', href: 'https://doi.org/10.1093/nar/gku744' },
    ],
  },
];

const additional = [
