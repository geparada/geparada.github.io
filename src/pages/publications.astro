---
<Layout title="Publications · Guillermo Parada">
  <h1 class="page-title">Publications</h1>
  <p class="page-lead">
    A selection of my peer-reviewed publications. A complete list is
    available on my
    <a href="https://scholar.google.com/citations?user=PTLeXysAAAAJ" target="_blank" rel="noopener">Google Scholar profile</a>.
  </p>

  <p class="note">
    <strong>Notation:</strong> <code>*</code> denotes equal contribution; <code>#</code> denotes
    corresponding author.
  </p>

  <section class="section">
    <h2 class="section-title">Selected publications</h2>
    <ul class="pub-list">
      {selected.map((p) => (
        <PublicationCard {...p} />
      ))}
    </ul>
  </section>

  <section class="section">
    <h2 class="section-title">Additional selected publications</h2>
    <ul class="pub-compact">
      {additional.map((entry) => (
        <li set:html={entry}></li>
      ))}
    </ul>
  </section>
</Layout>
